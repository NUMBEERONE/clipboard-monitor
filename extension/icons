# Run this once to generate placeholder icons
from PIL import Image
import os

icon_dir = r"E:\after\cybersecurity\clipboard\extension\icons"
os.makedirs(icon_dir, exist_ok=True)

for size in [16, 48, 128]:
    img = Image.new('RGB', (size, size), color='#2563eb')
    img.save(os.path.join(icon_dir, f'icon{size}.png'))

print("Icons created!")