// Whisper ClipGuard - Background Service Worker

chrome.runtime.onInstalled.addListener(() => {
    console.log('Whisper ClipGuard installed');
});

// Keep service worker alive
chrome.runtime.onMessage.addListener((message, sender, sendResponse) => {
    if (message.action === 'checkAgent') {
        fetch('http://127.0.0.1:9123/health')
            .then(res => res.json())
            .then(data => sendResponse({ connected: true }))
            .catch(() => sendResponse({ connected: false }));
        return true;
    }
});